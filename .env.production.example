# Copy this file to .env.production and replace all CHANGE_ME values.

# Host port mapping
APP_PORT=8080

# PostgreSQL container settings
POSTGRES_DB=shieldapi
POSTGRES_USER=shield
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Application datasource
DB_URL=jdbc:postgresql://postgres:5432/shieldapi
DB_USERNAME=shield
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION_MS=3600000

# Rate limiting
RATE_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BAN_THRESHOLD=3
RATE_LIMIT_BAN_SECONDS=300
